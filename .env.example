# Research Skills Environment Configuration
# Copy this file to .env and configure as needed.

# ==========================================
# 1. MCP Provider Overrides
# ==========================================
# By default, the system uses built-in default providers (like Semantic Scholar) 
# for scholarly-search and citation-graph.
# You can override these defaults by specifying your own MCP commands below.

# Example: Use a local Zotero MCP for searching instead of Semantic Scholar
# RESEARCH_MCP_SCHOLARLY_SEARCH_CMD="npx -y @zcaceres/zotero-mcp-server"

# Example: Use an external graph MCP
# RESEARCH_MCP_CITATION_GRAPH_CMD="python /path/to/your/custom_graph_mcp.py"

# Other configurable providers:
# RESEARCH_MCP_METADATA_REGISTRY_CMD=""
# RESEARCH_MCP_FULLTEXT_RETRIEVAL_CMD=""
# RESEARCH_MCP_PDF_PARSER_CMD=""
# RESEARCH_MCP_SCREENING_TRACKER_CMD=""
# RESEARCH_MCP_EXTRACTION_STORE_CMD=""
# RESEARCH_MCP_STATS_ENGINE_CMD=""
# RESEARCH_MCP_LINTER_CMD=""

# ==========================================
# 2. CLI UI Preferences
# ==========================================
# Set terminal output language (en or zh-CN)
RESEARCH_CLI_LANG="en"

# ==========================================
# 3. Model API Keys (If accessing directly via Orchestrator scripts)
# ==========================================
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."
# GEMINI_API_KEY="AIza..."
